# OAuth Configuration
# DO NOT USE NEXT_PUBLIC_ prefix for secrets - they will be exposed to the browser!
OAUTH_TOKEN_URL=https://your-identity-server.example.com/oauth2/token
OAUTH_CLIENT_ID=your_client_id_here
OAUTH_CLIENT_SECRET=your_client_secret_here
OAUTH_SCOPE=openid

# API Endpoints (Backend services)
MEMBERSHIP_SERVICE_URL=https://your-membership-service.example.com
INVOICE_SERVICE_URL=https://your-invoice-service.example.com

# Session Configuration
SESSION_SECRET=generate_a_random_secret_at_least_32_chars_long

# Environment
NODE_ENV=development
